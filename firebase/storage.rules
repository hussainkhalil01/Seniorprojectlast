rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to read/write their own uploads
    match /users/{userId}/uploads/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read all voice messages (sent by others)
    match /users/{userId}/uploads/{fileName} {
      allow read: if request.auth != null;
    }

    // Fallback: allow all authenticated reads and writes
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
