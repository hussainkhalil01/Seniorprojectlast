rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if caller is admin ──────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function orderDoc(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId));
    }

    match /users/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == document ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating_avg', 'rating_count']) ||
         isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == document || isAdmin());
    }

    // Reviews subcollection under each user
    match /users/{contractorId}/reviews/{reviewId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.reviewer_uid == request.auth.uid;
      allow delete: if request.auth != null &&
        (resource.data.reviewer_uid == request.auth.uid || isAdmin());
    }

    match /chat_messages/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    match /chats/{document} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /orders/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        (resource.data.provider_uid == request.auth.uid ||
         resource.data.client_uid == request.auth.uid ||
         isAdmin());
      allow update: if request.auth != null &&
        (resource.data.provider_uid == request.auth.uid ||
         resource.data.client_uid == request.auth.uid ||
         isAdmin());
      allow delete: if false;
    }

    match /app_notifications/{document} {
      allow create: if request.auth != null &&
        request.resource.data.sender_uid == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.recipient_uid == request.auth.uid || isAdmin());
      allow update: if request.auth != null &&
        (resource.data.recipient_uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /reviews/{document} {
      allow create: if request.auth != null &&
        request.resource.data.reviewer_uid == request.auth.uid &&
        request.resource.data.order_id is string &&
        document == request.resource.data.order_id + '_' + request.auth.uid &&
        exists(/databases/$(database)/documents/orders/$(request.resource.data.order_id)) &&
        orderDoc(request.resource.data.order_id).data.client_uid == request.auth.uid &&
        orderDoc(request.resource.data.order_id).data.status == 'completed' &&
        orderDoc(request.resource.data.order_id).data.provider_ref ==
          request.resource.data.contractor_ref;
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.reviewer_uid == request.auth.uid;
      allow delete: if request.auth != null &&
        (resource.data.reviewer_uid == request.auth.uid || isAdmin());
    }

    // Withdrawal requests — contractors create, admins approve/reject
    match /withdrawal_requests/{document} {
      allow create: if request.auth != null &&
        request.resource.data.user_uid == request.auth.uid;
      allow read: if request.auth != null &&
        (resource.data.user_uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Admin audit log — only admins write/read
    match /admin_logs/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
